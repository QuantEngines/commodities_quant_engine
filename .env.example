# Example environment variables
# Copy to .env and fill in actual values

# Zerodha KiteConnect API (live market data for MCX commodities)
# Get these from https://kite.zerodha.com/apps/myapps/new or existing app
ZERODHA_API_KEY=your_kiteconnect_api_key_here
ZERODHA_API_SECRET=your_kiteconnect_api_secret_here
ZERODHA_ACCESS_TOKEN=your_kiteconnect_access_token_here

# ICICI Breeze API (optional alternate MCX data source)
ICICI_BREEZE_API_KEY=your_icici_breeze_api_key_here
ICICI_BREEZE_SECRET_KEY=your_icici_breeze_secret_key_here
ICICI_BREEZE_SESSION_TOKEN=your_icici_breeze_session_token_here

# Optional LLM extraction runtime (OpenAI-compatible API)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_llm_api_key_here
LLM_TIMEOUT_SECONDS=20

# Data source API keys (if required)
MCX_API_KEY=your_mcx_api_key_here
NCDEX_API_KEY=your_ncdex_api_key_here
NSE_API_KEY=your_nse_api_key_here
FBIL_API_KEY=your_fbil_api_key_here

# Database paths
DATA_DIR=./data
CACHE_DIR=./cache

# Engine parameters
REGIME_WINDOW_DAYS=252
INEFFICIENCY_Z_THRESHOLD=2.0