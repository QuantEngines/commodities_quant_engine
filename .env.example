# Example environment variables
# Copy to .env and fill in actual values

# Data source API keys (if required)
MCX_API_KEY=your_mcx_api_key_here
NCDEX_API_KEY=your_ncdex_api_key_here
NSE_API_KEY=your_nse_api_key_here
FBIL_API_KEY=your_fbil_api_key_here

# Database paths
DATA_DIR=./data
CACHE_DIR=./cache

# Engine parameters
REGIME_WINDOW_DAYS=252
INEFFICIENCY_Z_THRESHOLD=2.0